<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rag_data_tree" model="ir.ui.view">
        <field name="name">rag.data.tree</field>
        <field name="model">rag.data</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="url" widget="url"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_rag_data_form" model="ir.ui.view">
        <field name="name">rag.data.form</field>
        <field name="model">rag.data</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Title..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="url" widget="url"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content">
                            <field name="content" placeholder="Describe the data..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
